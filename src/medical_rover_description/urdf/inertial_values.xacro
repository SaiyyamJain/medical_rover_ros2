<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Box Inertia -->
    <xacro:macro name="box_inertia" params="mass x y z">

        <inertial>

            <mass value="${mass}"/>

            <origin xyz="0 0 0" rpy="0 0 0"/>

            <inertia
                ixx="${(mass/12.0)*(y*y + z*z)}"
                ixy="0"
                ixz="0"

                iyy="${(mass/12.0)*(x*x + z*z)}"
                iyz="0"

                izz="${(mass/12.0)*(x*x + y*y)}"/>

        </inertial>

    </xacro:macro>


    <!-- Cylinder Inertia -->
    <xacro:macro name="cylinder_inertia" params="mass radius length">

        <inertial>

            <mass value="${mass}"/>

            <origin xyz="0 0 0" rpy="0 0 0"/>

            <inertia
                ixx="${mass*(3*radius*radius + length*length)/12.0}"
                ixy="0"
                ixz="0"

                iyy="${mass*(3*radius*radius + length*length)/12.0}"
                iyz="0"

                izz="${0.5*mass*radius*radius}"/>

        </inertial>

    </xacro:macro>


    <!-- Sphere Inertia -->
    <xacro:macro name="sphere_inertia" params="mass radius">

        <inertial>

            <mass value="${mass}"/>

            <origin xyz="0 0 0" rpy="0 0 0"/>

            <inertia
                ixx="${0.4*mass*radius*radius}"
                ixy="0"
                ixz="0"

                iyy="${0.4*mass*radius*radius}"
                iyz="0"

                izz="${0.4*mass*radius*radius}"/>

        </inertial>

    </xacro:macro>

</robot>